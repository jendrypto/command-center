# Command Center environment variables
# Copy to `.env` and fill in. `.env` is gitignored; do not commit real values.

# ───────────────────────────────────────────────────────────────────────────
# Promotion target (only needed if promotionTarget.type === "webhook" in
# command-space.config.ts). Leave blank to disable external promotion.
# ───────────────────────────────────────────────────────────────────────────

# The webhook URL that receives promoted items as JSON.
# Example endpoints: n8n, Zapier, Pipedream, Make, or a custom HTTP handler.
PROMOTION_WEBHOOK_URL=

# Optional bearer token for the webhook endpoint. Omit if not needed.
PROMOTION_WEBHOOK_TOKEN=

# ───────────────────────────────────────────────────────────────────────────
# MCP server
# ───────────────────────────────────────────────────────────────────────────

# The base URL the MCP server uses to reach the Next.js API. Only override
# if Command Center is running on a non-default port or a different host.
COMMAND_CENTER_URL=http://localhost:3005
