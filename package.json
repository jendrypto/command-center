{
  "name": "command-center",
  "version": "0.1.0",
  "description": "A command space for your agent — MCP-enabled workspace with a dashboard, cron-ready.",
  "license": "MIT",
  "scripts": {
    "dev": "next dev -H 127.0.0.1 -p 3005",
    "dev:lan": "next dev -H 0.0.0.0 -p 3005",
    "build": "next build",
    "start": "next start -H 127.0.0.1 -p 3005",
    "start:lan": "next start -H 0.0.0.0 -p 3005",
    "lint": "eslint .",
    "mcp:build": "cd mcp-server && npm install --silent && npm run build",
    "mcp:start": "node mcp-server/dist/index.js"
  },
  "dependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.16",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "lucide-react": "^1.8.0",
    "next": "^16.2.4",
    "postcss": "^8.4.32",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sqlite3": "^6.0.1",
    "tailwindcss": "^3.3.0",
    "typescript": "^5.3.0"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6"
  }
